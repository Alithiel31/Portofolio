# ── Backend ───────────────────────────────────────────────────────────────────
# Copier ce fichier en .env dans le dossier backend/

# PostgreSQL — LOCAL (docker compose)
DATABASE_URL="postgresql://portfolio:portfolio_dev@localhost:5432/portfolio"

# PostgreSQL — PRODUCTION (Railway injecte cette variable automatiquement)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB"

NODE_ENV="development"
PORT=3000

# URL du frontend en prod (pour CORS) — Railway URL de votre service
# FRONTEND_URL="https://votre-portfolio.up.railway.app"
