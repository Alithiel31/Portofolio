generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id          Int      @id @default(autoincrement())
  name        String
  title       String
  bio         String   @db.Text
  photoUrl    String?
  email       String?
  location    String?
  cvUrl       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  socialLinks SocialLink[]
}

model SocialLink {
  id        Int     @id @default(autoincrement())
  platform  String
  url       String
  icon      String
  order     Int     @default(0)
  profileId Int
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Experience {
  id          Int      @id @default(autoincrement())
  year        String
  title       String
  company     String
  description String   @db.Text
  type        ExperienceType @default(WORK)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ExperienceType {
  WORK
  EDUCATION
}

model SkillCategory {
  id     Int     @id @default(autoincrement())
  name   String
  icon   String?
  order  Int     @default(0)
  skills Skill[]
}

model Skill {
  id         Int           @id @default(autoincrement())
  name       String
  type       SkillType     @default(MAIN)
  parent     String?
  order      Int           @default(0)
  categoryId Int
  category   SkillCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

enum SkillType {
  MAIN
  FRAMEWORK
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  techStack   String
  imageUrl    String?
  demoUrl     String?
  githubUrl   String?
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  icon        String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
